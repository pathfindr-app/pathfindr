{
  "name": "pathfindr",
  "version": "1.0.0",
  "description": "Race against AI to find the shortest path through real city streets",
  "main": "game.js",
  "scripts": {
    "start": "npx serve .",
    "start:stream": "node scripts/stream-server.js",
    "start:chat": "node scripts/youtube-worker-launcher.js",
    "start:watchdog": "node scripts/stream-watchdog.js",
    "start:stream:all": "./scripts/start-stream-stack.sh",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "restart:pm2": "pm2 restart ecosystem.config.cjs",
    "setup:stream": "node scripts/setup-stream-env.js",
    "setup:youtube": "node scripts/youtube-oauth-init.js",
    "deploy:stream:functions": "./scripts/deploy-stream-functions.sh",
    "build": "node scripts/build.js",
    "build:mobile": "npm run build && npx cap sync",
    "ios": "npm run build:mobile && npx cap open ios",
    "android": "npm run build:mobile && npx cap open android",
    "add:ios": "npx cap add ios",
    "add:android": "npx cap add android"
  },
  "keywords": [
    "game",
    "pathfinding",
    "maps",
    "astar"
  ],
  "author": "Pathfindr",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.1",
    "@revenuecat/purchases-capacitor": "^12.0.3",
    "@supabase/supabase-js": "^2.89.0"
  }
}
