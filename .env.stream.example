# Pathfindr stream runtime example env
# Copy values into .env.local using: npm run setup:stream
# Additional values below can be added manually as needed.

# Stream runtime mode
# local: use built-in queue server (works immediately on VPS)
# supabase: use Supabase queue functions
STREAM_BACKEND_MODE=local

# Queue target for YouTube worker
# Local VPS stream server:
STREAM_QUEUE_API_URL=http://127.0.0.1:3000/api/requests
# Optional queue write key (set same value on stream server + worker)
STREAM_QUEUE_API_KEY=replace-with-long-random-string
# Supabase Edge function option:
# STREAM_QUEUE_API_URL=https://your-project-ref.supabase.co/functions/v1/stream-queue-request

# YouTube worker switch
# Keep false until YouTube Live and OAuth are ready.
STREAM_ENABLE_YT_WORKER=false
# Monetization switch: if true, chat worker/server ignore free chat requests.
STREAM_PAID_ONLY=false

# Supabase (optional for now)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Required for YouTube chat worker
YT_CLIENT_ID=your-google-oauth-client-id
YT_CLIENT_SECRET=your-google-oauth-client-secret
YT_REFRESH_TOKEN=your-oauth-refresh-token

# Optional: provide one of these if auto-discovery is not enough
# YT_LIVE_CHAT_ID=
# YT_LIVE_BROADCAST_ID=

# Worker behavior tuning
YT_POLL_FALLBACK_MS=5000
YT_RETRY_DELAY_MS=10000
STREAM_USER_COOLDOWN_MS=120000
STREAM_CITY_DEDUPE_MS=600000
STREAM_COLLAPSE_PAID_DUPLICATES=false
STREAM_MAX_MESSAGE_CACHE=5000
STREAM_MAX_WINDOW_ENTRIES=3000
YT_WORKER_PERSIST_STATE_MS=8000
# Optional local queue dedupe history size
STREAM_MAX_PROCESSED_IDS=10000
# Optional custom worker state location
# YT_WORKER_STATE_FILE=/path/to/youtube-worker-state.json
STREAM_DRY_RUN=false
STREAM_VERBOSE=true

# Watchdog (optional)
# WATCHDOG_HEALTH_URL=http://127.0.0.1:3000/api/health
# WATCHDOG_STATE_URL=http://127.0.0.1:3000/api/stream-state
# WATCHDOG_INTERVAL_MS=15000
# WATCHDOG_MAX_FAILURES=4
# WATCHDOG_STALE_STATE_MS=240000
# WATCHDOG_RESTART_CMD=pm2 restart ecosystem.config.cjs
# WATCHDOG_RESTART_COOLDOWN_MS=180000
# WATCHDOG_ALERT_WEBHOOK_URL=
